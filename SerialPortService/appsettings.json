{
  "Urls": "http://0.0.0.0:9600",
  "WebSocket": {
    "KeepAliveSeconds": 30,
    "MaxConnections": 100,
    "ReceiveBufferSize": 4096
  },
  "SerialPort": {
    "DefaultBaudRate": 9600,
    "ReadTimeoutMs": 500,
    "WriteTimeoutMs": 500,
    "NewLine": "\r\n"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/serialport-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
